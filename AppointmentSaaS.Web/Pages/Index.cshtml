@page
@model IndexModel
@{
    ViewData["Title"] = "Globe Appointment Management";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h1 class="display-4 fw-bold text-primary">Globe Appointment Management</h1>
            <p class="lead text-muted mt-3">Streamline your scheduling with our powerful multi-tenant appointment platform.</p>
            <div class="mt-4 d-flex gap-3 justify-content-center">
                <a asp-page="/Auth/Login" class="btn btn-primary btn-lg px-5">Sign In</a>
                <a asp-page="/Auth/Register" class="btn btn-outline-primary btn-lg px-5">Get Started</a>
            </div>
        </div>
    </div>
    <div class="row mt-5 g-4">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="fs-1 mb-3">📅</div>
                    <h5 class="card-title">Easy Scheduling</h5>
                    <p class="card-text text-muted">Book appointments in seconds with our intuitive interface.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="fs-1 mb-3">🏢</div>
                    <h5 class="card-title">Multi-Tenant</h5>
                    <p class="card-text text-muted">Fully isolated tenant environments for each business.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body text-center p-4">
                    <div class="fs-1 mb-3">🔒</div>
                    <h5 class="card-title">Secure & Reliable</h5>
                    <p class="card-text text-muted">JWT authentication with refresh tokens for maximum security.</p>
                </div>
            </div>
        </div>
    </div>
</div>
