@page
@model AppointmentSaaS.Web.Pages.Appointments.CreateModel
@{
    ViewData["Title"] = "New Appointment";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Book New Appointment</h5>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                        <div class="mb-3">
                            <label asp-for="Input.ServiceId" class="form-label fw-semibold">Service</label>
                            <select asp-for="Input.ServiceId" asp-items="Model.ServiceOptions" class="form-select">
                                <option value="">-- Select Service --</option>
                            </select>
                            <span asp-validation-for="Input.ServiceId" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Input.StaffId" class="form-label fw-semibold">Staff Member</label>
                            <select asp-for="Input.StaffId" asp-items="Model.StaffOptions" class="form-select">
                                <option value="">-- Select Staff --</option>
                            </select>
                            <span asp-validation-for="Input.StaffId" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Input.StartTime" class="form-label fw-semibold">Date & Time</label>
                            <input asp-for="Input.StartTime" type="datetime-local" class="form-control" />
                            <span asp-validation-for="Input.StartTime" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Input.Notes" class="form-label fw-semibold">Notes (optional)</label>
                            <textarea asp-for="Input.Notes" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">Book Appointment</button>
                            <a asp-page="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
