@page
@model AppointmentSaaS.Web.Pages.Auth.LoginModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "_Layout";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0">Sign In</h4>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                        <div class="mb-3">
                            <label asp-for="Input.TenantSlug" class="form-label fw-semibold">Organization</label>
                            <input asp-for="Input.TenantSlug" class="form-control" placeholder="your-organization" />
                            <span asp-validation-for="Input.TenantSlug" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Input.Email" class="form-label fw-semibold">Email</label>
                            <input asp-for="Input.Email" class="form-control" placeholder="you@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Input.Password" class="form-label fw-semibold">Password</label>
                            <input asp-for="Input.Password" type="password" class="form-control" />
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">Sign In</button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center py-3">
                    <small>Don't have an account? <a asp-page="/Auth/Register">Register here</a></small>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
